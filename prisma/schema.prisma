// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("CLIENT") // "CLIENT", "ADMIN", "AGENT"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  inquiries     Inquiry[]
}

model Property {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  location    String
  bedrooms    Int
  bathrooms   Int
  area        Float    // Square meters
  images      String   // JSON stringified array of URLs
  amenities   String   // JSON stringified array
  status      String   @default("AVAILABLE") // "AVAILABLE", "SOLD", "RENTED"
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  inquiries   Inquiry[]
}

model Inquiry {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name        String
  email       String
  phone       String?
  message     String
  status      String   @default("PENDING") // "PENDING", "CONTACTED", "RESOLVED"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
